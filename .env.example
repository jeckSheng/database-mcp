# 复制此文件为 .env，填写真实信息，在 databases.yaml 中通过 ${VAR_NAME} 引用

# 生产环境 MySQL（prod_mysql）
MYSQL_PROD_HOST=localhost
MYSQL_PROD_PORT=3306
MYSQL_PROD_DATABASE=mydb
MYSQL_PROD_USER=root
MYSQL_PROD_PASSWORD=123456
MYSQL_PROD_ALLOW_READ=true
MYSQL_PROD_ALLOW_WRITE=false
MYSQL_PROD_ALLOW_DDL=false

# 测试环境 MySQL（dev_mysql）
MYSQL_TEST_HOST=localhost
MYSQL_TEST_PORT=3306
MYSQL_TEST_DATABASE=test
MYSQL_TEST_USER=root
MYSQL_TEST_PASSWORD=123456
MYSQL_TEST_ALLOW_READ=true
MYSQL_TEST_ALLOW_WRITE=true
MYSQL_TEST_ALLOW_DDL=true

# PostgreSQL 分析库（analytics_pg，如需启用请在 databases.yaml 中取消注释）
# PG_ANALYTICS_PASSWORD=123456
